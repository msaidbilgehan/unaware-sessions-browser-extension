{
  "name": "unaware-sessions-browser-extension",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Privacy-first multi-session browser manager - entirely local",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.{ts,svelte,html,css,json}'",
    "format:check": "prettier --check 'src/**/*.{ts,svelte,html,css,json}'",
    "version": "node scripts/sync-manifest-version.cjs && git add manifest.json",
    "release": "npm version patch && git push origin --follow-tags",
    "release:minor": "npm version minor && git push origin --follow-tags",
    "release:major": "npm version major && git push origin --follow-tags"
  },
  "dependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.27",
    "@eslint/js": "^9.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "chrome-types": "^0.1.327",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-svelte": "^3.0.0",
    "fake-indexeddb": "^6.0.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.4.0",
    "prettier-plugin-svelte": "^3.3.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
